        }
    }
}

public static void printReverse() {
	if(bookList.isEmpty()) {
		System.out.println("No books found!");
	}else {
		for(int i=bookList.size() -1;i>=0;i--) {
			System.out.println(bookList.get(i));
		}
	}
}

public static boolean deleteBook(String[] isbn) {
	for(Book b : bookList) {
		if(b.getIsbn().equals(isbn[0])) {
			bookList.remove(b);
			return true;
		}
	}
	return false;
}

